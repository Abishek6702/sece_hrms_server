{
  "info": {
    "name": "Attendance Override APIs",
    "_postman_id": "attendance-override-collection",
    "description": "Collection for attendance override history and remark APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "employeeId",
      "value": "",
      "type": "string"
    },
    {
      "key": "recordId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "List Overrides",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/attendance-override?page=1&limit=50", "host": ["{{baseUrl}}"], "path": ["api","attendance-override"] }
      }
    },
    {
      "name": "Get Override By ID",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/attendance-override/record/{{recordId}}", "host": ["{{baseUrl}}"], "path": ["api","attendance-override","record","{{recordId}}"] }
      }
    },
    {
      "name": "Get Overrides By Employee",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/attendance-override/employee/{{employeeId}}?start=2026-06-01&end=2026-06-09", "host": ["{{baseUrl}}"], "path": ["api","attendance-override","employee","{{employeeId}}"] }
      }
    },
    {
      "name": "Get Overrides By Date",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/attendance-override/date/2026-06-08", "host": ["{{baseUrl}}"], "path": ["api","attendance-override","date","2026-06-08"] }
      }
    },
    {
      "name": "Create/Upsert Override",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"facultyId\": \"<facultyId>\",\n  \"attendanceDate\": \"2026-06-08\",\n  \"session1\": \"A\",\n  \"session2\": \"P\",\n  \"remarks\": \"Manual correction\",\n  \"overriddenBy\": \"<userId>\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/attendance-override", "host": ["{{baseUrl}}"], "path": ["api","attendance-override"] }
      }
    },
    {
      "name": "Update Override",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{ \"session1\": \"P\", \"session2\": \"P\", \"remarks\": \"Corrected\", \"overriddenBy\": \"<userId>\" }" },
        "url": { "raw": "{{baseUrl}}/api/attendance-override/{{recordId}}", "host": ["{{baseUrl}}"], "path": ["api","attendance-override","{{recordId}}"] }
      }
    },
    {
      "name": "Update Override By Employee and Date",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{ \"session1\": \"A\", \"session2\": \"P\", \"remarks\": \"Date-specific update\", \"overriddenBy\": \"<userId>\" }" },
        "url": { "raw": "{{baseUrl}}/api/attendance-override/employee/{{employeeId}}/date/2026-06-08", "host": ["{{baseUrl}}"], "path": ["api","attendance-override","employee","{{employeeId}}","date","2026-06-08"] }
      }
    },
    {
      "name": "Bulk Update By Employee",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"facultyId\": \"<facultyId>\",\n  \"overrides\": [\n    {\n      \"attendanceDate\": \"2026-06-08\",\n      \"session1\": \"P\",\n      \"session2\": \"P\",\n      \"remarks\": \"Bulk correction\"\n    }\n  ],\n  \"overriddenBy\": \"<userId>\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/attendance-override/bulk/employee", "host": ["{{baseUrl}}"], "path": ["api","attendance-override","bulk","employee"] }
      }
    },
    {
      "name": "Bulk Update By Date",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"attendanceDate\": \"2026-06-08\",\n  \"overrides\": [\n    { \"facultyId\": \"<facultyId>\", \"session1\": \"A\", \"session2\": \"P\", \"remarks\": \"Bulk date edit\" }\n  ],\n  \"overriddenBy\": \"<userId>\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/attendance-override/bulk/date", "host": ["{{baseUrl}}"], "path": ["api","attendance-override","bulk","date"] }
      }
    },
    {
      "name": "Upsert Remark (single)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{ \"facultyId\": \"<facultyId>\", \"attendanceDate\": \"2026-06-08\", \"remarks\": \"Late arrival\", \"overriddenBy\": \"<userId>\" }" },
        "url": { "raw": "{{baseUrl}}/api/attendance-override/remark", "host": ["{{baseUrl}}"], "path": ["api","attendance-override","remark"] }
      }
    },
    {
      "name": "Update Remark By ID",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{ \"remarks\": \"Adjusted remark\", \"overriddenBy\": \"<userId>\" }" },
        "url": { "raw": "{{baseUrl}}/api/attendance-override/remark/{{recordId}}", "host": ["{{baseUrl}}"], "path": ["api","attendance-override","remark","{{recordId}}"] }
      }
    },
    {
      "name": "Bulk Remarks By Employee",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{ \"facultyId\": \"<facultyId>\", \"remarksEntries\": [ { \"attendanceDate\": \"2026-06-01\", \"remarks\": \"Note 1\" } ], \"overriddenBy\": \"<userId>\" }" },
        "url": { "raw": "{{baseUrl}}/api/attendance-override/remark/bulk/employee", "host": ["{{baseUrl}}"], "path": ["api","attendance-override","remark","bulk","employee"] }
      }
    },
    {
      "name": "Bulk Remarks By Date",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{ \"attendanceDate\": \"2026-06-08\", \"entries\": [ { \"facultyId\": \"<facultyId>\", \"remarks\": \"Note for date\" } ], \"overriddenBy\": \"<userId>\" }" },
        "url": { "raw": "{{baseUrl}}/api/attendance-override/remark/bulk/date", "host": ["{{baseUrl}}"], "path": ["api","attendance-override","remark","bulk","date"] }
      }
    }
  ]
}
